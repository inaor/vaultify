{
  "patterns": [
    {"id": "aws_access_key_id", "regex": "AKIA[0-9A-Z]{16}", "severity": "critical", "description": "AWS Access Key ID", "ignore_case": false},
    {"id": "aws_temp_access_key_id", "regex": "ASIA[0-9A-Z]{16}", "severity": "critical", "description": "AWS temporary Access Key ID", "ignore_case": false},
    {"id": "gh_pat_classic", "regex": "ghp_[A-Za-z0-9]{36,}", "severity": "critical", "description": "GitHub personal access token (classic)", "ignore_case": false},
    {"id": "gh_pat_fine", "regex": "github_pat_[A-Za-z0-9_]+", "severity": "critical", "description": "GitHub fine-grained PAT", "ignore_case": false},
    {"id": "github_oauth", "regex": "gho_[A-Za-z0-9]{36,}", "severity": "high", "description": "GitHub OAuth token", "ignore_case": false},
    {"id": "github_app", "regex": "ghu_[A-Za-z0-9]{36,}|ghs_[A-Za-z0-9]{36,}|ghr_[A-Za-z0-9]{36,}", "severity": "high", "description": "GitHub app/user token", "ignore_case": false},
    {"id": "gitlab_pat", "regex": "glpat-[A-Za-z0-9\\-]{20,}", "severity": "critical", "description": "GitLab personal access token", "ignore_case": false},
    {"id": "slack_bot", "regex": "xoxb-[0-9A-Za-z\\-]{50,}", "severity": "high", "description": "Slack bot token", "ignore_case": false},
    {"id": "slack_user", "regex": "xoxp-[0-9A-Za-z\\-]{50,}", "severity": "high", "description": "Slack user token", "ignore_case": false},
    {"id": "slack_app", "regex": "xoxa-[0-9A-Za-z\\-]{50,}", "severity": "high", "description": "Slack app-level token", "ignore_case": false},
    {"id": "slack_webhook", "regex": "https://hooks\\.slack\\.com/services/[A-Za-z0-9/]+", "severity": "medium", "description": "Slack incoming webhook URL", "ignore_case": false},
    {"id": "stripe_secret", "regex": "sk_live_[0-9a-zA-Z]{24,}|sk_test_[0-9a-zA-Z]{24,}|rk_live_[0-9a-zA-Z]{24,}|rk_test_[0-9a-zA-Z]{24,}", "severity": "critical", "description": "Stripe secret or restricted key", "ignore_case": false},
    {"id": "anthropic_api", "regex": "sk-ant-api[A-Za-z0-9\\-_]{10,}", "severity": "critical", "description": "Anthropic API key", "ignore_case": false},
    {"id": "openai_project", "regex": "sk-proj-[A-Za-z0-9\\-_]{20,}", "severity": "critical", "description": "OpenAI project API key", "ignore_case": false},
    {"id": "openai_legacy", "regex": "sk-[A-Za-z0-9]{20,}", "severity": "critical", "description": "OpenAI API key (legacy shape)", "ignore_case": false},
    {"id": "google_api_key", "regex": "AIza[0-9A-Za-z\\-_]{35}", "severity": "high", "description": "Google API key", "ignore_case": false},
    {"id": "npm_token", "regex": "npm_[A-Za-z0-9]{36,}", "severity": "high", "description": "npm token", "ignore_case": false},
    {"id": "atlassian_api_token", "regex": "ATATT3[A-Za-z0-9+/=]{20,}", "severity": "critical", "description": "Atlassian Cloud API token", "ignore_case": false},
    {"id": "shopify_token", "regex": "shpat_[A-Za-z0-9]{32,}|shpca_[A-Za-z0-9]{32,}|shpss_[A-Za-z0-9]{32,}", "severity": "critical", "description": "Shopify access token", "ignore_case": false},
    {"id": "sendgrid", "regex": "SG\\.[A-Za-z0-9_\\-]{22,}\\.[A-Za-z0-9_\\-]{43,}", "severity": "critical", "description": "SendGrid API key", "ignore_case": false},
    {"id": "twilio", "regex": "AC[0-9a-f]{32}", "severity": "medium", "description": "Twilio Account SID", "ignore_case": false},
    {"id": "twilio_auth", "regex": "SK[0-9a-f]{32}", "severity": "high", "description": "Twilio API key SID", "ignore_case": false},
    {"id": "telegram_bot", "regex": "[0-9]{8,10}:[A-Za-z0-9_-]{35}", "severity": "medium", "description": "Telegram bot token", "ignore_case": false},
    {"id": "databricks", "regex": "dapi[a-f0-9]{32,}", "severity": "critical", "description": "Databricks personal access token", "ignore_case": false},
    {"id": "pulumi", "regex": "pulumi-[a-f0-9]{40,}", "severity": "high", "description": "Pulumi access token", "ignore_case": false},
    {"id": "notion", "regex": "secret_[A-Za-z0-9]{40,}", "severity": "high", "description": "Notion integration secret", "ignore_case": false},
    {"id": "linear", "regex": "lin_api_[A-Za-z0-9]{40,}", "severity": "high", "description": "Linear API key", "ignore_case": false},
    {"id": "mailgun", "regex": "key-[0-9a-zA-Z]{32}", "severity": "high", "description": "Mailgun private API key", "ignore_case": false},
    {"id": "jwt", "regex": "eyJ[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}", "severity": "low", "description": "JWT-shaped string", "ignore_case": false},
    {"id": "private_key_block", "regex": "-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY-----", "severity": "critical", "description": "PEM private key header", "ignore_case": false}
  ]
}
