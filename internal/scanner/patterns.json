{
  "patterns": [
    {"id": "aws_access_key_id", "prefix": "AKIA", "regex": "AKIA[0-9A-Z]{16}", "severity": "critical", "description": "AWS Access Key ID", "ignore_case": false, "added_in": "0.1.0"},
    {"id": "aws_temp_access_key_id", "prefix": "ASIA", "regex": "ASIA[0-9A-Z]{16}", "severity": "critical", "description": "AWS temporary Access Key ID", "ignore_case": false, "added_in": "0.1.0"},
    {"id": "gh_pat_classic", "prefix": "ghp_", "regex": "ghp_[A-Za-z0-9]{36,}", "severity": "critical", "description": "GitHub personal access token (classic)", "ignore_case": false, "added_in": "0.1.0"},
    {"id": "gh_pat_fine", "prefix": "github_pat_", "regex": "github_pat_[A-Za-z0-9_]+", "severity": "critical", "description": "GitHub fine-grained PAT", "ignore_case": false, "added_in": "0.1.0"},
    {"id": "github_oauth", "prefix": "gho_", "regex": "gho_[A-Za-z0-9]{36,}", "severity": "high", "description": "GitHub OAuth token", "ignore_case": false, "added_in": "0.1.0"},
    {"id": "github_app", "prefix": "gh", "regex": "ghu_[A-Za-z0-9]{36,}|ghs_[A-Za-z0-9]{36,}|ghr_[A-Za-z0-9]{36,}", "severity": "high", "description": "GitHub app/user token", "ignore_case": false, "added_in": "0.1.0"},
    {"id": "gitlab_pat", "prefix": "glpat-", "regex": "glpat-[A-Za-z0-9\\-]{20,}", "severity": "critical", "description": "GitLab personal access token", "ignore_case": false, "added_in": "0.1.0"},
    {"id": "bitbucket_app_password", "prefix": "ATBB", "regex": "ATBB[A-Za-z0-9]{32,}", "severity": "critical", "description": "Bitbucket app password", "ignore_case": false, "added_in": "0.1.3"},
    {"id": "slack_bot", "prefix": "xoxb-", "regex": "xoxb-[0-9A-Za-z\\-]{50,}", "severity": "high", "description": "Slack bot token", "ignore_case": false, "added_in": "0.1.0"},
    {"id": "slack_user", "prefix": "xoxp-", "regex": "xoxp-[0-9A-Za-z\\-]{50,}", "severity": "high", "description": "Slack user token", "ignore_case": false, "added_in": "0.1.0"},
    {"id": "slack_app", "prefix": "xoxa-", "regex": "xoxa-[0-9A-Za-z\\-]{50,}", "severity": "high", "description": "Slack app-level token", "ignore_case": false, "added_in": "0.1.0"},
    {"id": "slack_webhook", "prefix": "hooks.slack.com", "regex": "https://hooks\\.slack\\.com/services/[A-Za-z0-9/]+", "severity": "medium", "description": "Slack incoming webhook URL", "ignore_case": false, "added_in": "0.1.0"},
    {"id": "teams_webhook", "prefix": "webhook.office.com", "regex": "https://[a-z0-9]+\\.webhook\\.office\\.com/webhookb2/[A-Za-z0-9\\-@/]+", "severity": "medium", "description": "Microsoft Teams webhook URL", "ignore_case": false, "added_in": "0.1.3"},
    {"id": "discord_bot", "prefix": "", "regex": "[MN][A-Za-z0-9]{23,}\\.[A-Za-z0-9\\-_]{6}\\.[A-Za-z0-9\\-_]{27,}", "severity": "high", "description": "Discord bot token", "ignore_case": false, "added_in": "0.1.3"},
    {"id": "stripe_secret", "prefix": "sk_", "regex": "sk_live_[0-9a-zA-Z]{24,}|sk_test_[0-9a-zA-Z]{24,}|rk_live_[0-9a-zA-Z]{24,}|rk_test_[0-9a-zA-Z]{24,}", "severity": "critical", "description": "Stripe secret or restricted key", "ignore_case": false, "added_in": "0.1.0"},
    {"id": "anthropic_api", "prefix": "sk-ant-api", "regex": "sk-ant-api[A-Za-z0-9\\-_]{10,}", "severity": "critical", "description": "Anthropic API key", "ignore_case": false, "added_in": "0.1.0"},
    {"id": "openai_project", "prefix": "sk-proj-", "regex": "sk-proj-[A-Za-z0-9\\-_]{20,}", "severity": "critical", "description": "OpenAI project API key", "ignore_case": false, "added_in": "0.1.0"},
    {"id": "openai_legacy", "prefix": "sk-", "regex": "sk-[A-Za-z0-9]{20,}", "severity": "critical", "description": "OpenAI API key (legacy shape)", "min_entropy": 3.8, "ignore_case": false, "added_in": "0.1.0"},
    {"id": "google_api_key", "prefix": "AIza", "regex": "AIza[0-9A-Za-z\\-_]{35}", "severity": "high", "description": "Google API key", "ignore_case": false, "added_in": "0.1.0"},
    {"id": "npm_token", "prefix": "npm_", "regex": "npm_[A-Za-z0-9]{36,}", "severity": "high", "description": "npm token", "ignore_case": false, "added_in": "0.1.0"},
    {"id": "pypi_token", "prefix": "pypi-", "regex": "pypi-[A-Za-z0-9\\-_]{50,}", "severity": "high", "description": "PyPI API token", "ignore_case": false, "added_in": "0.1.3"},
    {"id": "nuget_api", "prefix": "oy2", "regex": "oy2[a-z0-9]{15,}[A-Za-z0-9]{28}", "severity": "high", "description": "NuGet API key", "min_entropy": 4.0, "ignore_case": false, "added_in": "0.1.3"},
    {"id": "atlassian_api_token", "prefix": "ATATT3", "regex": "ATATT3[A-Za-z0-9+/=]{20,}", "severity": "critical", "description": "Atlassian Cloud API token (Jira/Confluence)", "ignore_case": false, "added_in": "0.1.0"},
    {"id": "shopify_token", "prefix": "shp", "regex": "shpat_[A-Za-z0-9]{32,}|shpca_[A-Za-z0-9]{32,}|shpss_[A-Za-z0-9]{32,}", "severity": "critical", "description": "Shopify access token", "ignore_case": false, "added_in": "0.1.0"},
    {"id": "sendgrid", "prefix": "SG.", "regex": "SG\\.[A-Za-z0-9_\\-]{22,}\\.[A-Za-z0-9_\\-]{43,}", "severity": "critical", "description": "SendGrid API key", "ignore_case": false, "added_in": "0.1.0"},
    {"id": "twilio", "prefix": "AC", "regex": "AC[0-9a-f]{32}", "severity": "medium", "description": "Twilio Account SID", "ignore_case": false, "added_in": "0.1.0"},
    {"id": "twilio_auth", "prefix": "SK", "regex": "SK[0-9a-f]{32}", "severity": "high", "description": "Twilio API key SID", "ignore_case": false, "added_in": "0.1.0"},
    {"id": "telegram_bot", "prefix": "", "regex": "[0-9]{8,10}:[A-Za-z0-9_\\-]{35,}", "severity": "medium", "description": "Telegram bot token", "min_entropy": 3.8, "ignore_case": false, "added_in": "0.1.0"},
    {"id": "dropbox_token", "prefix": "sl.", "regex": "sl\\.[A-Za-z0-9\\-_]{100,}", "severity": "high", "description": "Dropbox short-lived access token", "ignore_case": false, "added_in": "0.1.3"},
    {"id": "figma_pat", "prefix": "figd_", "regex": "figd_[A-Za-z0-9\\-_]{40,}", "severity": "high", "description": "Figma personal access token", "ignore_case": false, "added_in": "0.1.3"},
    {"id": "hubspot_private_app", "prefix": "pat-na", "regex": "pat-na[12]-[a-f0-9\\-]{30,}", "severity": "high", "description": "HubSpot private app token", "ignore_case": false, "added_in": "0.1.3"},
    {"id": "contentful_pat", "prefix": "CFPAT-", "regex": "CFPAT-[A-Za-z0-9\\-_]{43}", "severity": "high", "description": "Contentful personal access token", "ignore_case": false, "added_in": "0.1.3"},
    {"id": "postman_api", "prefix": "PMAK-", "regex": "PMAK-[a-f0-9]{24}-[a-f0-9]{34}", "severity": "high", "description": "Postman API key", "ignore_case": false, "added_in": "0.1.3"},
    {"id": "supabase_key", "prefix": "sbp_", "regex": "sbp_[a-f0-9]{40,}", "severity": "high", "description": "Supabase service key", "ignore_case": false, "added_in": "0.1.3"},
    {"id": "airtable_pat", "prefix": "pat", "regex": "pat[A-Za-z0-9]{14}\\.[a-f0-9]{64}", "severity": "high", "description": "Airtable personal access token", "ignore_case": false, "added_in": "0.1.3"},
    {"id": "planetscale_token", "prefix": "pscale_tkn_", "regex": "pscale_tkn_[A-Za-z0-9_\\-]{43,}", "severity": "high", "description": "PlanetScale service token", "ignore_case": false, "added_in": "0.1.3"},
    {"id": "databricks", "prefix": "dapi", "regex": "dapi[a-f0-9]{32,}", "severity": "critical", "description": "Databricks personal access token", "ignore_case": false, "added_in": "0.1.0"},
    {"id": "pulumi", "prefix": "pulumi-", "regex": "pulumi-[a-f0-9]{40,}", "severity": "high", "description": "Pulumi access token", "ignore_case": false, "added_in": "0.1.0"},
    {"id": "notion", "prefix": "secret_", "regex": "secret_[A-Za-z0-9]{40,}", "severity": "high", "description": "Notion integration secret", "ignore_case": false, "added_in": "0.1.0"},
    {"id": "linear", "prefix": "lin_api_", "regex": "lin_api_[A-Za-z0-9]{40,}", "severity": "high", "description": "Linear API key", "ignore_case": false, "added_in": "0.1.0"},
    {"id": "mailgun", "prefix": "key-", "regex": "key-[0-9a-zA-Z]{32}", "severity": "high", "description": "Mailgun private API key", "ignore_case": false, "added_in": "0.1.0"},
    {"id": "hashicorp_vault_token", "prefix": "hvs.", "regex": "hvs\\.[A-Za-z0-9_\\-]{24,}", "severity": "critical", "description": "HashiCorp Vault service token", "ignore_case": false, "added_in": "0.1.3"},
    {"id": "hashicorp_tf_token", "prefix": "atlasv1", "regex": "[a-zA-Z0-9]{14}\\.atlasv1\\.[A-Za-z0-9]{60,}", "severity": "critical", "description": "Terraform Cloud/Enterprise token", "ignore_case": false, "added_in": "0.1.3"},
    {"id": "doppler_token", "prefix": "dp.", "regex": "dp\\.(st|ct|sa|scrt|audit)\\.[A-Za-z0-9]{40,}", "severity": "high", "description": "Doppler service token", "ignore_case": false, "added_in": "0.1.3"},
    {"id": "docker_pat", "prefix": "dckr_pat_", "regex": "dckr_pat_[A-Za-z0-9\\-_]{27,}", "severity": "high", "description": "Docker Hub personal access token", "ignore_case": false, "added_in": "0.1.3"},
    {"id": "grafana_service", "prefix": "glsa_", "regex": "glsa_[A-Za-z0-9_]{32,}", "severity": "high", "description": "Grafana service account token", "ignore_case": false, "added_in": "0.1.3"},
    {"id": "grafana_cloud", "prefix": "glc_", "regex": "glc_[A-Za-z0-9+/=]{32,}", "severity": "high", "description": "Grafana Cloud API key", "ignore_case": false, "added_in": "0.1.3"},
    {"id": "dynatrace_token", "prefix": "dt0c01.", "regex": "dt0c01\\.[A-Z0-9]{24}\\.[A-Z0-9]{64}", "severity": "critical", "description": "Dynatrace API token", "ignore_case": false, "added_in": "0.1.3"},
    {"id": "newrelic_user_api", "prefix": "NRAK-", "regex": "NRAK-[A-Z0-9]{27}", "severity": "high", "description": "New Relic user API key", "ignore_case": false, "added_in": "0.1.3"},
    {"id": "newrelic_insert", "prefix": "NRII-", "regex": "NRII-[A-Za-z0-9\\-_]{32}", "severity": "high", "description": "New Relic insights insert key", "ignore_case": false, "added_in": "0.1.3"},
    {"id": "artifactory_token", "prefix": "AKCp", "regex": "AKCp[A-Za-z0-9]{69,}", "severity": "high", "description": "JFrog Artifactory token", "min_entropy": 4.0, "ignore_case": false, "added_in": "0.1.3"},
    {"id": "age_secret_key", "prefix": "AGE-SECRET-KEY-", "regex": "AGE-SECRET-KEY-[A-Z0-9]{58,}", "severity": "critical", "description": "age encryption secret key", "ignore_case": false, "added_in": "0.1.3"},
    {"id": "jwt", "prefix": "eyJ", "regex": "eyJ[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}", "severity": "low", "description": "JWT-shaped string (Okta/Zoom/Monday/Azure AD)", "ignore_case": false, "added_in": "0.1.0"},
    {"id": "private_key_block", "prefix": "-----BEGIN", "regex": "-----BEGIN (RSA |EC |OPENSSH |DSA )?PRIVATE KEY-----", "severity": "critical", "description": "PEM private key header (VPN/SSH/TLS)", "ignore_case": false, "added_in": "0.1.0"}
  ]
}
